{
  "manifest_version": 3,
  "name": "WA Lead Sender",
  "description": "Carga leads desde CSV/Excel/Sheets y automatiza envíos en WhatsApp Web.",
  "version": "1.1.0",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://docs.google.com/*"
  ],
  "action": {
    "default_title": "WA Lead Sender",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
